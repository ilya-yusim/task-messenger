{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
                
        {
                "name": "Attach to Dispatcher Process",
                "type": "cppdbg",
                "request": "attach",
                "program": "/usr/src/app/dispatcher-executable", // Path to the executable in the container
                "processId": "${command:pickProcess}", // Allows you to select the process
                "MIMode": "gdb",
                "miDebuggerPath": "/usr/bin/gdb", // Path to gdb in the container
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
        },
        {
            "name": "(Windows) Attach",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}"
        },
        {
            "name": "Worker",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/builddir/worker/tm-worker.exe",
            "args": ["-c", "config/config-worker.json","--mode","blocking"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal"
        },
        {
            "name": "Worker (async)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/builddir/worker/tm-worker.exe",
            "args": ["-c", "config/config-worker.json","--mode","async"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal"
        },
        {
            "name": "worker (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/builddir/worker/tm-worker",
            "args": ["-c", "config/config-worker.json","--mode","blocking"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Worker Python Script",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/builddir-worker/worker/startWorkerAndVN.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/worker",
            "env": {
                "MANAGER_IP": "10.147.20.0",
                "MANAGER_PORT": "8080"
            }
        },
        {
            "name": "Dispatcher (Python wrapper)",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/builddir-dispatcher/dispatcher/startDispatcherAndVN.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/builddir-dispatcher/dispatcher",
            "env": {
                "MANAGER_PORT": "8080"
            }
        },
        {
            "name": "Interactive Generator",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/builddir/generators/interactive/tm-generator-interactive.exe",
            "args": ["-c", "config/config-dispatcher.json"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "Interactive Generator (verify failure)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/builddir/generators/interactive/tm-generator-interactive.exe",
            "args": ["-c", "config/config-dispatcher.json","--verify","--verify-inject-failure"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "Interactive Generator (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/builddir/generators/interactive/tm-generator-interactive",
            "args": ["-c", "config/config-dispatcher.json"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}